---
// src/components/Footer.astro
---

<footer class="bg-slate-950 text-slate-400 py-12 border-t border-slate-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
      
      <!-- Colonne 1 : À propos / Logo -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <!-- Logo ou Texte alternatif si le logo blanc est sur fond noir -->
          <span class="text-white font-black text-xl tracking-wider">YAM LOGISTICS <span class="text-[#3b82f6]">LLC</span></span>
        </div>
        <p class="text-xs leading-relaxed max-w-sm text-slate-500">
          YAM LOGISTICS LLC is an independent truck dispatch agency. We work directly with professional carriers to secure top-paying loads and streamline logistics workflows nationwide.
        </p>
      </div>

      <!-- Colonne 2 : Liens rapides -->
      <div>
        <h4 class="text-sm font-bold uppercase tracking-wider text-white mb-4">Quick Links</h4>
        <ul class="space-y-2 text-xs">
          <li><a href="#home" class="hover:text-white transition-colors">Home</a></li>
          <li><a href="#about" class="hover:text-white transition-colors">About Us</a></li>
          <li><a href="#services" class="hover:text-white transition-colors">Our Services</a></li>
          <li><a href="#contact" class="hover:text-white transition-colors">Contact Us</a></li>
        </ul>
      </div>

      <!-- Colonne 3 : Légal & Conformité USA -->
      <div>
        <h4 class="text-sm font-bold uppercase tracking-wider text-white mb-4">Compliance</h4>
        <ul class="space-y-2 text-xs text-slate-500">
          <li>YAM LOGISTICS LLC</li>
          <li>Based in Oklahoma City, OK</li>
          <li>Independent Dispatch Agency</li>
          <li>Reliable & FMCSA Compliant</li>
        </ul>
      </div>

    </div>

    <!-- Ligne de Copyright tout en bas -->
    <div class="border-t border-slate-900 pt-8 flex flex-col sm:flex-row justify-center items-center gap-4 text-xs text-slate-600">
      <p>© 2026 YAM LOGISTICS LLC. All rights reserved.</p>
    </div>
  </div>
</footer>