---
// src/components/Services.astro
---

<section id="services" class="py-20 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- En-tête de section -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <p class="text-xs font-bold tracking-widest text-[#0252b9] uppercase">Our Services</p>
      <h2 class="mt-2 text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight">
        Solutions That Keep You Moving
      </h2>
      <div class="w-16 h-1 bg-[#0252b9] mx-auto mt-4 rounded-full"></div>
    </div>

    <!-- Grille des services (4 cartes) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      
      <!-- Service 1 : Freight Dispatch -->
      <div class="bg-white p-8 rounded-xl border border-slate-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-1 duration-300">
        <div class="w-12 h-12 rounded-lg bg-blue-50 text-[#0252b9] flex items-center justify-center mb-6">
          <!-- Icône Camion -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-slate-900 mb-3">Freight Dispatch</h3>
        <p class="text-sm text-slate-500 leading-relaxed">
          We handle load booking, negotiation, and paperwork so you can focus on driving and safety.
        </p>
      </div>

      <!-- Service 2 : Load Planning -->
      <div class="bg-white p-8 rounded-xl border border-slate-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-1 duration-300">
        <div class="w-12 h-12 rounded-lg bg-blue-50 text-[#0252b9] flex items-center justify-center mb-6">
          <!-- Icône Presse-papiers / Planification -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-slate-900 mb-3">Load Planning</h3>
        <p class="text-sm text-slate-500 leading-relaxed">
          We find the best paying loads and plan efficient routes to maximize your weekly revenue.
        </p>
      </div>

      <!-- Service 3 : Paperwork -->
      <div class="bg-white p-8 rounded-xl border border-slate-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-1 duration-300">
        <div class="w-12 h-12 rounded-lg bg-blue-50 text-[#0252b9] flex items-center justify-center mb-6">
          <!-- Icône Document -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-slate-900 mb-3">Paperwork</h3>
        <p class="text-sm text-slate-500 leading-relaxed">
          We manage rate confirmations, setup sheets, and all the required broker paperwork accurately.
        </p>
      </div>

      <!-- Service 4 : 24/7 Support -->
      <div class="bg-white p-8 rounded-xl border border-slate-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-1 duration-300">
        <div class="w-12 h-12 rounded-lg bg-blue-50 text-[#0252b9] flex items-center justify-center mb-6">
          <!-- Icône Casque Audio / Support -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-slate-900 mb-3">24/7 Support</h3>
        <p class="text-sm text-slate-500 leading-relaxed">
          Round-the-clock assistance whenever you or your drivers need help while on the road.
        </p>
      </div>

    </div>
  </div>
</section>